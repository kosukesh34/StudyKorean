default_platform(:ios)

platform :ios do
  private_lane :asc_api_key do
    key_content = ENV["APP_STORE_CONNECT_API_KEY_KEY_CONTENT"]
    key_filepath = ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]

    if key_content.to_s.empty? && key_filepath.to_s.empty?
      UI.user_error!("Set APP_STORE_CONNECT_API_KEY_KEY_CONTENT or APP_STORE_CONNECT_API_KEY_KEY_FILEPATH")
    end

    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID"),
      issuer_id: (ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"].to_s.empty? ? nil : ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"]),
      key_content: key_content.to_s.empty? ? nil : key_content,
      key_filepath: key_filepath.to_s.empty? ? nil : key_filepath,
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )
  end

  private_lane :build_release do
    build_number = ENV["BUILD_NUMBER"]
    increment_build_number(build_number: build_number) unless build_number.to_s.empty?

    build_app(
      project: "StudyKorean.xcodeproj",
      scheme: "StudyKorean",
      clean: true,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: "T29T2L39T5"
      },
      output_directory: "./build",
      output_name: "StudyKorean.ipa"
    )
  end

  private_lane :upload_and_submit do |options|
    api_key = asc_api_key
    build_release

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      distribute_external: options[:external] == true,
      groups: options[:groups],
      changelog: options[:changelog]
    )

    upload_to_app_store(
      api_key: api_key,
      precheck_include_in_app_purchases: false,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      submit_for_review: true,
      automatic_release: false,
      force: true
    )
  end

  desc "Always upload to TestFlight and submit for App Store review"
  lane :deploy do |options|
    upload_and_submit(options)
  end

  desc "Alias: behaves same as deploy (always TestFlight + review submission)"
  lane :beta do |options|
    upload_and_submit(options)
  end

  desc "Alias: behaves same as deploy (always TestFlight + review submission)"
  lane :submit_review do |options|
    upload_and_submit(options)
  end

  desc "Validate required env vars only"
  lane :doctor do
    required = [
      "APP_STORE_CONNECT_API_KEY_KEY_ID"
    ]

    required.each do |k|
      UI.user_error!("Missing env: #{k}") if ENV[k].to_s.empty?
    end

    key_content = ENV["APP_STORE_CONNECT_API_KEY_KEY_CONTENT"].to_s
    key_filepath = ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"].to_s
    UI.user_error!("Set API key content or file path") if key_content.empty? && key_filepath.empty?

    UI.message("doctor passed")
  end
end
